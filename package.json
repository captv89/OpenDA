{
	"name": "openda",
	"version": "1.0.0",
	"private": true,
	"description": "OpenDA — AI Disbursement Account Analyzer (monorepo root)",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0",
		"pnpm": ">=9.0.0"
	},
	"scripts": {
		"dev:accountant": "pnpm --filter frontend-accountant dev",
		"dev:operator": "pnpm --filter frontend-operator dev",
		"build": "pnpm --filter \"./frontend-*\" --filter \"./packages/*\" build",
		"lint": "pnpm --filter \"./frontend-*\" --filter \"./packages/*\" lint",
		"typecheck": "pnpm --filter \"./frontend-*\" --filter \"./packages/*\" typecheck"
	}
}
