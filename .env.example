# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://openda:openda@localhost:5432/openda

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Webhook ────────────────────────────────────────────────────────────────────
# Set to your ERP webhook endpoint; leave as-is to use the built-in debug echo
WEBHOOK_URL=http://localhost:8000/api/v1/da/webhook-echo

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
