# ── LLM Provider (via LiteLLM — swap without code changes) ───────────────────
# Anthropic Claude (default)
LLM_MODEL=anthropic/claude-sonnet-4-6-20250514
LLM_API_KEY=sk-ant-your-key-here

# ── Alternative provider examples (uncomment one block to switch) ─────────────
# Google Gemini
# LLM_MODEL=gemini/gemini-2.0-flash
# LLM_API_KEY=AIza-your-google-ai-key

# OpenAI
# LLM_MODEL=openai/gpt-4o
# LLM_API_KEY=sk-your-openai-key

# Ollama (local — no API key required)
# LLM_MODEL=ollama/llama3.3
# LLM_API_KEY=ollama
# OLLAMA_API_BASE=http://localhost:11434

# Azure OpenAI
# LLM_MODEL=azure/gpt-4o
# LLM_API_KEY=your-azure-key
# AZURE_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_VERSION=2024-02-15-preview

# ── LLM Behaviour ──────────────────────────────────────────────────────────────
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.0
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://openda:openda@localhost:5432/openda

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Webhook ────────────────────────────────────────────────────────────────────
# Set to your ERP webhook endpoint; leave as-is to use the built-in debug echo
WEBHOOK_URL=http://localhost:8000/api/v1/da/webhook-echo

# ── Legacy / direct SDK keys (only needed if NOT using LiteLLM routing) ───────
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Storage ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
